{
  "$defs": {
    "checkerReport": {
      "additionalProperties": false,
      "properties": {
        "accepted": {
          "type": "boolean"
        },
        "artifact_hashes": {
          "additionalProperties": {
            "$ref": "#/$defs/hash256"
          },
          "type": "object"
        },
        "checker_policy_hash": {
          "$ref": "#/$defs/hash256"
        },
        "computed_residuals": {
          "items": {
            "$ref": "#/$defs/residualResult"
          },
          "type": "array"
        },
        "containment_result": {
          "$ref": "#/$defs/componentResult"
        },
        "contract_version": {
          "const": "rcp-rclm-runtime-contract-v2.0.0"
        },
        "domain_result": {
          "$ref": "#/$defs/componentResult"
        },
        "evaluation_result": {
          "$ref": "#/$defs/componentResult"
        },
        "invariant_result": {
          "$ref": "#/$defs/componentResult"
        },
        "lean_bridge_result": {
          "$ref": "#/$defs/componentResult"
        },
        "metric_bounds": {
          "oneOf": [
            {
              "$ref": "#/$defs/metricBounds"
            },
            {
              "type": "null"
            }
          ]
        },
        "monitor_result": {
          "$ref": "#/$defs/componentResult"
        },
        "progress_result": {
          "$ref": "#/$defs/componentResult"
        },
        "protected_nonloss_result": {
          "$ref": "#/$defs/componentResult"
        },
        "reason_codes": {
          "items": {
            "enum": [
              "SCHEMA_UNKNOWN",
              "SCHEMA_MALFORMED",
              "CANONICALIZATION_FAILED",
              "HASH_MISMATCH",
              "PARENT_LINK_MISMATCH",
              "TRUST_ANCHOR_CHANGED",
              "UNSUPPORTED_SCOPE",
              "TYPE_MISMATCH",
              "TYPED_SUCCESSOR_FAILED",
              "RESIDUAL_POSITIVE",
              "NONLOSS_FAILED",
              "RECOVERY_FAILED",
              "INVARIANT_FAILED",
              "PROGRESS_REGRESSION",
              "STRICT_WITNESS_FAILED",
              "TRUST_INVALID",
              "RESOURCE_INVALID",
              "CONTAINMENT_FAILED",
              "SUCCESSOR_DOMAIN_FAILED",
              "REFINEMENT_MISMATCH",
              "MONITOR_FAILED",
              "NUMERIC_INDETERMINATE",
              "LEAN_SOURCE_FORBIDDEN_TOKEN",
              "LEAN_VERIFIER_FAILED",
              "PROVENANCE_FAILED",
              "MANUAL_REPAIR_DETECTED",
              "INTERNAL_ERROR"
            ]
          },
          "type": "array",
          "uniqueItems": true
        },
        "recovery_result": {
          "$ref": "#/$defs/componentResult"
        },
        "refinement_result": {
          "$ref": "#/$defs/componentResult"
        },
        "residual_result": {
          "$ref": "#/$defs/componentResult"
        },
        "resource_result": {
          "$ref": "#/$defs/componentResult"
        },
        "schema_id": {
          "const": "runtime.phase3_checker_report.v2"
        },
        "strict_witness_result": {
          "$ref": "#/$defs/componentResult"
        },
        "structural_result": {
          "$ref": "#/$defs/componentResult"
        },
        "transition_id": {
          "minLength": 1,
          "type": "string"
        },
        "trust_result": {
          "$ref": "#/$defs/componentResult"
        },
        "typed_successor_result": {
          "$ref": "#/$defs/componentResult"
        },
        "verdict": {
          "enum": [
            "accept",
            "reject",
            "indeterminate"
          ]
        }
      },
      "required": [
        "schema_id",
        "contract_version",
        "transition_id",
        "verdict",
        "accepted",
        "reason_codes",
        "structural_result",
        "typed_successor_result",
        "computed_residuals",
        "residual_result",
        "metric_bounds",
        "evaluation_result",
        "protected_nonloss_result",
        "recovery_result",
        "invariant_result",
        "containment_result",
        "progress_result",
        "strict_witness_result",
        "trust_result",
        "resource_result",
        "domain_result",
        "refinement_result",
        "monitor_result",
        "lean_bridge_result",
        "artifact_hashes",
        "checker_policy_hash"
      ],
      "type": "object"
    },
    "checkerRequest": {
      "additionalProperties": false,
      "properties": {
        "candidate": {
          "$ref": "#/$defs/rclmCandidate"
        },
        "certificate": {
          "$ref": "https://github.com/n9269017/rcp-rclm/schemas/runtime_records.v2.json#/$defs/rclmCertificatePacket"
        },
        "contract_version": {
          "const": "rcp-rclm-runtime-contract-v2.0.0"
        },
        "evaluation_evidence": {
          "$ref": "#/$defs/evaluationEvidence"
        },
        "lean_bridge_report": {
          "$ref": "#/$defs/leanBridgeReport"
        },
        "predecessor": {
          "$ref": "https://github.com/n9269017/rcp-rclm/schemas/runtime_records.v2.json#/$defs/rclmState"
        },
        "protected_distinctions": {
          "items": {
            "$ref": "#/$defs/protectedDistinction"
          },
          "type": "array",
          "uniqueItems": true
        },
        "resource_record": {
          "$ref": "#/$defs/resourceRecord"
        },
        "schema_id": {
          "const": "runtime.phase3_checker_request.v2"
        },
        "transition_id": {
          "minLength": 1,
          "type": "string"
        },
        "trust_anchor": {
          "$ref": "#/$defs/trustAnchor"
        }
      },
      "required": [
        "schema_id",
        "contract_version",
        "transition_id",
        "predecessor",
        "candidate",
        "certificate",
        "trust_anchor",
        "resource_record",
        "protected_distinctions",
        "evaluation_evidence",
        "lean_bridge_report"
      ],
      "type": "object"
    },
    "componentResult": {
      "additionalProperties": false,
      "properties": {
        "evidence": {},
        "reason_codes": {
          "items": {
            "enum": [
              "SCHEMA_UNKNOWN",
              "SCHEMA_MALFORMED",
              "CANONICALIZATION_FAILED",
              "HASH_MISMATCH",
              "PARENT_LINK_MISMATCH",
              "TRUST_ANCHOR_CHANGED",
              "UNSUPPORTED_SCOPE",
              "TYPE_MISMATCH",
              "TYPED_SUCCESSOR_FAILED",
              "RESIDUAL_POSITIVE",
              "NONLOSS_FAILED",
              "RECOVERY_FAILED",
              "INVARIANT_FAILED",
              "PROGRESS_REGRESSION",
              "STRICT_WITNESS_FAILED",
              "TRUST_INVALID",
              "RESOURCE_INVALID",
              "CONTAINMENT_FAILED",
              "SUCCESSOR_DOMAIN_FAILED",
              "REFINEMENT_MISMATCH",
              "MONITOR_FAILED",
              "NUMERIC_INDETERMINATE",
              "LEAN_SOURCE_FORBIDDEN_TOKEN",
              "LEAN_VERIFIER_FAILED",
              "PROVENANCE_FAILED",
              "MANUAL_REPAIR_DETECTED",
              "INTERNAL_ERROR"
            ]
          },
          "type": "array",
          "uniqueItems": true
        },
        "schema_id": {
          "const": "runtime.phase3_component_result.v2"
        },
        "status": {
          "enum": [
            "pass",
            "fail",
            "indeterminate",
            "not_evaluated"
          ]
        }
      },
      "required": [
        "schema_id",
        "status",
        "reason_codes",
        "evidence"
      ],
      "type": "object"
    },
    "evaluationEvidence": {
      "additionalProperties": false,
      "properties": {
        "evaluator_policy_hash": {
          "$ref": "#/$defs/hash256"
        },
        "predecessor_observation": {
          "type": "object"
        },
        "schema_id": {
          "const": "runtime.phase3_evaluation_evidence.v2"
        },
        "scope": {
          "enum": [
            "gate_b_classical",
            "gate_c_diagonal_quantum"
          ]
        },
        "successor_observation": {
          "type": "object"
        },
        "target_observation": {
          "type": "object"
        }
      },
      "required": [
        "schema_id",
        "scope",
        "predecessor_observation",
        "successor_observation",
        "target_observation",
        "evaluator_policy_hash"
      ],
      "type": "object"
    },
    "gitObject": {
      "pattern": "^[0-9a-f]{40}$",
      "type": "string"
    },
    "hash256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "interval": {
      "additionalProperties": false,
      "properties": {
        "lower": {
          "$ref": "#/$defs/rational"
        },
        "precision_bits": {
          "maximum": 4096,
          "minimum": 128,
          "type": "integer"
        },
        "schema_id": {
          "const": "runtime.interval_evidence.v2"
        },
        "upper": {
          "$ref": "#/$defs/rational"
        }
      },
      "required": [
        "schema_id",
        "lower",
        "upper",
        "precision_bits"
      ],
      "type": "object"
    },
    "leanBridgeReport": {
      "additionalProperties": false,
      "properties": {
        "bridge_verdict": {
          "enum": [
            "accept",
            "reject",
            "indeterminate"
          ]
        },
        "case_id": {
          "minLength": 1,
          "type": "string"
        },
        "compiler_duration_ms": {
          "minimum": 0,
          "type": "integer"
        },
        "compiler_report": {
          "$ref": "https://github.com/n9269017/rcp-rclm/schemas/runtime_records.v2.json#/$defs/leanVerifierReport"
        },
        "contract_version": {
          "const": "rcp-rclm-runtime-contract-v2.0.0"
        },
        "differential_match": {
          "type": "boolean"
        },
        "error_detail_hash": {
          "$ref": "#/$defs/hash256"
        },
        "expected_acceptance": {
          "type": "boolean"
        },
        "generated_source_hash": {
          "$ref": "#/$defs/hash256"
        },
        "generated_source_path": {
          "minLength": 1,
          "type": "string"
        },
        "lean_rclm_acceptance": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "lean_rcp_acceptance": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "packet_hash": {
          "$ref": "#/$defs/hash256"
        },
        "project_pin_hash": {
          "$ref": "#/$defs/hash256"
        },
        "reason_codes": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "schema_id": {
          "const": "runtime.lean_bridge_verification_report.v2"
        },
        "scope": {
          "enum": [
            "gate_b_classical",
            "gate_c_diagonal_quantum"
          ]
        },
        "source_guard_hash": {
          "$ref": "#/$defs/hash256"
        },
        "theorem_surface_hash": {
          "$ref": "#/$defs/hash256"
        },
        "timed_out": {
          "type": "boolean"
        },
        "toolchain_runtime_hash": {
          "$ref": "#/$defs/hash256"
        }
      },
      "required": [
        "schema_id",
        "contract_version",
        "bridge_verdict",
        "reason_codes",
        "case_id",
        "scope",
        "packet_hash",
        "expected_acceptance",
        "lean_rcp_acceptance",
        "lean_rclm_acceptance",
        "differential_match",
        "generated_source_path",
        "generated_source_hash",
        "theorem_surface_hash",
        "project_pin_hash",
        "toolchain_runtime_hash",
        "source_guard_hash",
        "error_detail_hash",
        "compiler_report",
        "compiler_duration_ms",
        "timed_out"
      ],
      "type": "object"
    },
    "metricBounds": {
      "additionalProperties": false,
      "properties": {
        "divergence_after": {
          "$ref": "#/$defs/interval"
        },
        "divergence_before": {
          "$ref": "#/$defs/interval"
        },
        "entropy_after": {
          "$ref": "#/$defs/interval"
        },
        "entropy_before": {
          "$ref": "#/$defs/interval"
        },
        "entropy_target": {
          "$ref": "#/$defs/interval"
        },
        "gap": {
          "$ref": "#/$defs/interval"
        },
        "progress_after": {
          "$ref": "#/$defs/interval"
        },
        "progress_before": {
          "$ref": "#/$defs/interval"
        },
        "progress_delta": {
          "$ref": "#/$defs/interval"
        },
        "schema_id": {
          "const": "runtime.phase3_metric_bounds.v2"
        },
        "scope": {
          "enum": [
            "gate_b_classical",
            "gate_c_diagonal_quantum"
          ]
        }
      },
      "required": [
        "schema_id",
        "scope",
        "gap",
        "entropy_before",
        "entropy_after",
        "entropy_target",
        "divergence_before",
        "divergence_after",
        "progress_before",
        "progress_after",
        "progress_delta"
      ],
      "type": "object"
    },
    "protectedDistinction": {
      "additionalProperties": false,
      "properties": {
        "distinction_id": {
          "enum": [
            "target_fit",
            "normalization",
            "trace_one",
            "entropy_preserved"
          ]
        },
        "loss_budget": {
          "$ref": "#/$defs/rational"
        },
        "schema_id": {
          "const": "runtime.phase3_protected_distinction.v2"
        }
      },
      "required": [
        "schema_id",
        "distinction_id",
        "loss_budget"
      ],
      "type": "object"
    },
    "rational": {
      "additionalProperties": false,
      "properties": {
        "denominator": {
          "pattern": "^[1-9][0-9]*$",
          "type": "string"
        },
        "numerator": {
          "pattern": "^(0|-?[1-9][0-9]*)$",
          "type": "string"
        }
      },
      "required": [
        "numerator",
        "denominator"
      ],
      "type": "object"
    },
    "rclmCandidate": {
      "additionalProperties": false,
      "properties": {
        "next": {
          "$ref": "https://github.com/n9269017/rcp-rclm/schemas/runtime_records.v2.json#/$defs/rclmState"
        },
        "schema_id": {
          "const": "rclm.candidate.v2"
        },
        "update": {
          "$ref": "https://github.com/n9269017/rcp-rclm/schemas/runtime_records.v2.json#/$defs/rclmUpdate"
        }
      },
      "required": [
        "schema_id",
        "update",
        "next"
      ],
      "type": "object"
    },
    "residualResult": {
      "additionalProperties": false,
      "properties": {
        "index": {
          "enum": [
            "typed",
            "packet"
          ]
        },
        "schema_id": {
          "const": "runtime.phase3_residual_result.v2"
        },
        "upper_nonpositive": {
          "type": "boolean"
        },
        "value": {
          "$ref": "#/$defs/rational"
        }
      },
      "required": [
        "schema_id",
        "index",
        "value",
        "upper_nonpositive"
      ],
      "type": "object"
    },
    "resourceRecord": {
      "additionalProperties": false,
      "properties": {
        "budget_units": {
          "minimum": 0,
          "type": "integer"
        },
        "candidate_write_attempts": {
          "minimum": 0,
          "type": "integer"
        },
        "checker_source_write_attempts": {
          "minimum": 0,
          "type": "integer"
        },
        "consumed_units": {
          "minimum": 0,
          "type": "integer"
        },
        "environment_hash": {
          "$ref": "#/$defs/hash256"
        },
        "hidden_oracle_reads": {
          "minimum": 0,
          "type": "integer"
        },
        "manual_repair_count": {
          "minimum": 0,
          "type": "integer"
        },
        "meter_policy_hash": {
          "$ref": "#/$defs/hash256"
        },
        "model_invocations": {
          "minimum": 0,
          "type": "integer"
        },
        "network_requests": {
          "minimum": 0,
          "type": "integer"
        },
        "precision_bits": {
          "maximum": 4096,
          "minimum": 128,
          "type": "integer"
        },
        "predecessor_write_attempts": {
          "minimum": 0,
          "type": "integer"
        },
        "schema_id": {
          "const": "runtime.phase3_resource_record.v2"
        }
      },
      "required": [
        "schema_id",
        "budget_units",
        "consumed_units",
        "precision_bits",
        "model_invocations",
        "network_requests",
        "predecessor_write_attempts",
        "candidate_write_attempts",
        "checker_source_write_attempts",
        "manual_repair_count",
        "hidden_oracle_reads",
        "environment_hash",
        "meter_policy_hash"
      ],
      "type": "object"
    },
    "trustAnchor": {
      "additionalProperties": false,
      "properties": {
        "checker_policy_hash": {
          "$ref": "#/$defs/hash256"
        },
        "claim_boundary_hash": {
          "$ref": "#/$defs/hash256"
        },
        "formal_manifest_blob": {
          "$ref": "#/$defs/gitObject"
        },
        "formal_source_commit": {
          "$ref": "#/$defs/gitObject"
        },
        "gate_c_audit_sha256": {
          "$ref": "#/$defs/hash256"
        },
        "lean_toolchain": {
          "const": "leanprover/lean4:v4.31.0"
        },
        "lean_verifier_policy_hash": {
          "$ref": "#/$defs/hash256"
        },
        "mathlib_commit": {
          "$ref": "#/$defs/gitObject"
        },
        "schema_id": {
          "const": "runtime.phase3_trust_anchor.v2"
        }
      },
      "required": [
        "schema_id",
        "formal_source_commit",
        "lean_toolchain",
        "mathlib_commit",
        "formal_manifest_blob",
        "gate_c_audit_sha256",
        "checker_policy_hash",
        "lean_verifier_policy_hash",
        "claim_boundary_hash"
      ],
      "type": "object"
    }
  },
  "$id": "https://github.com/n9269017/rcp-rclm/schemas/phase_3_checker.v2.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "oneOf": [
    {
      "$ref": "#/$defs/checkerRequest"
    },
    {
      "$ref": "#/$defs/checkerReport"
    }
  ],
  "title": "RCP/RCLM Executable Core v2 Phase 3 checker records"
}
