{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/n9269017/rcp-rclm/schemas/phase_4_adversarial.v2.json",
  "title": "RCP/RCLM Executable Core v2 Phase 4 hardened checker and adversarial records",
  "oneOf": [
    {"$ref": "#/$defs/hardenedRequest"},
    {"$ref": "#/$defs/hardenedReport"},
    {"$ref": "#/$defs/attackCaseResult"},
    {"$ref": "#/$defs/attackSuiteReport"}
  ],
  "$defs": {
    "hash256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "canonicalNonnegativeInteger": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)$"
    },
    "reasonCode": {
      "enum": [
        "SCHEMA_UNKNOWN",
        "SCHEMA_MALFORMED",
        "CANONICALIZATION_FAILED",
        "HASH_MISMATCH",
        "PARENT_LINK_MISMATCH",
        "TRUST_ANCHOR_CHANGED",
        "UNSUPPORTED_SCOPE",
        "TYPE_MISMATCH",
        "TYPED_SUCCESSOR_FAILED",
        "RESIDUAL_POSITIVE",
        "NONLOSS_FAILED",
        "RECOVERY_FAILED",
        "INVARIANT_FAILED",
        "PROGRESS_REGRESSION",
        "STRICT_WITNESS_FAILED",
        "TRUST_INVALID",
        "RESOURCE_INVALID",
        "CONTAINMENT_FAILED",
        "SUCCESSOR_DOMAIN_FAILED",
        "REFINEMENT_MISMATCH",
        "MONITOR_FAILED",
        "NUMERIC_INDETERMINATE",
        "LEAN_SOURCE_FORBIDDEN_TOKEN",
        "LEAN_VERIFIER_FAILED",
        "PROVENANCE_FAILED",
        "MANUAL_REPAIR_DETECTED",
        "INTERNAL_ERROR"
      ]
    },
    "semanticFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "mode", "size", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "mode": {"enum": ["0644", "0755"]},
        "size": {"$ref": "#/$defs/canonicalNonnegativeInteger"},
        "sha256": {"$ref": "#/$defs/hash256"}
      }
    },
    "packageManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_id",
        "contract_version",
        "package_id",
        "parent_package_id",
        "parent_manifest_hash",
        "semantic_tree_hash",
        "candidate_hash",
        "certificate_packet_hash",
        "checker_policy_hash",
        "lean_verifier_policy_hash",
        "trust_anchor_hash",
        "resource_record_hash",
        "claim_boundary_hash"
      ],
      "properties": {
        "schema_id": {"const": "runtime.package_manifest.v2"},
        "contract_version": {"const": "rcp-rclm-runtime-contract-v2.0.0"},
        "package_id": {"type": "string", "minLength": 1},
        "parent_package_id": {"type": ["string", "null"]},
        "parent_manifest_hash": {
          "oneOf": [
            {"$ref": "#/$defs/hash256"},
            {"type": "null"}
          ]
        },
        "semantic_tree_hash": {"$ref": "#/$defs/hash256"},
        "candidate_hash": {"$ref": "#/$defs/hash256"},
        "certificate_packet_hash": {"$ref": "#/$defs/hash256"},
        "checker_policy_hash": {"$ref": "#/$defs/hash256"},
        "lean_verifier_policy_hash": {"$ref": "#/$defs/hash256"},
        "trust_anchor_hash": {"$ref": "#/$defs/hash256"},
        "resource_record_hash": {"$ref": "#/$defs/hash256"},
        "claim_boundary_hash": {"$ref": "#/$defs/hash256"}
      }
    },
    "packageIntegrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_id",
        "predecessor_manifest",
        "candidate_manifest",
        "predecessor_files",
        "candidate_files",
        "checker_manifest_hash",
        "transition_binding_hash"
      ],
      "properties": {
        "schema_id": {"const": "runtime.phase4_package_integrity.v2"},
        "predecessor_manifest": {"$ref": "#/$defs/packageManifest"},
        "candidate_manifest": {"$ref": "#/$defs/packageManifest"},
        "predecessor_files": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/semanticFile"}
        },
        "candidate_files": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/semanticFile"}
        },
        "checker_manifest_hash": {"$ref": "#/$defs/hash256"},
        "transition_binding_hash": {"$ref": "#/$defs/hash256"}
      }
    },
    "hardenedRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_id",
        "contract_version",
        "checker_request",
        "package_integrity"
      ],
      "properties": {
        "schema_id": {"const": "runtime.phase4_hardened_checker_request.v2"},
        "contract_version": {"const": "rcp-rclm-runtime-contract-v2.0.0"},
        "checker_request": {
          "$ref": "phase_3_checker.schema.json#/$defs/checkerRequest"
        },
        "package_integrity": {"$ref": "#/$defs/packageIntegrity"}
      }
    },
    "hardenedReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_id",
        "contract_version",
        "transition_id",
        "verdict",
        "accepted",
        "reason_codes",
        "integrity_result",
        "checker_report",
        "artifact_hashes"
      ],
      "properties": {
        "schema_id": {"const": "runtime.phase4_hardened_checker_report.v2"},
        "contract_version": {"const": "rcp-rclm-runtime-contract-v2.0.0"},
        "transition_id": {"type": "string", "minLength": 1},
        "verdict": {"enum": ["accept", "reject", "indeterminate"]},
        "accepted": {"type": "boolean"},
        "reason_codes": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/reasonCode"}
        },
        "integrity_result": {
          "$ref": "phase_3_checker.schema.json#/$defs/componentResult"
        },
        "checker_report": {
          "oneOf": [
            {"$ref": "phase_3_checker.schema.json#/$defs/checkerReport"},
            {"type": "null"}
          ]
        },
        "artifact_hashes": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/hash256"}
        }
      }
    },
    "attackCaseResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_id",
        "case_id",
        "attack_class",
        "expected_verdict",
        "expected_reason_codes",
        "observed_verdict",
        "observed_reason_codes",
        "first_observation_hash",
        "second_observation_hash",
        "deterministic_replay",
        "passed",
        "evidence"
      ],
      "properties": {
        "schema_id": {"const": "runtime.phase4_attack_case_result.v2"},
        "case_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{0,159}$"
        },
        "attack_class": {"type": "string", "minLength": 1},
        "expected_verdict": {"enum": ["reject", "indeterminate"]},
        "expected_reason_codes": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "observed_verdict": {"enum": ["accept", "reject", "indeterminate"]},
        "observed_reason_codes": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "first_observation_hash": {"$ref": "#/$defs/hash256"},
        "second_observation_hash": {"$ref": "#/$defs/hash256"},
        "deterministic_replay": {"type": "boolean"},
        "passed": {"type": "boolean"},
        "evidence": {}
      }
    },
    "attackSuiteReport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_id",
        "suite_version",
        "contract_version",
        "case_count",
        "passed_count",
        "failed_count",
        "all_passed",
        "results"
      ],
      "properties": {
        "schema_id": {"const": "runtime.phase4_attack_suite_report.v2"},
        "suite_version": {"const": "rcp-rclm-runtime-phase-4-adversarial-v1"},
        "contract_version": {"const": "rcp-rclm-runtime-contract-v2.0.0"},
        "case_count": {"type": "integer", "minimum": 1},
        "passed_count": {"type": "integer", "minimum": 0},
        "failed_count": {"type": "integer", "minimum": 0},
        "all_passed": {"type": "boolean"},
        "results": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/attackCaseResult"}
        }
      }
    }
  }
}
