{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rcp-rclm.example/schemas/runtime-v3-phase-12c-memory-retrieval.json",
  "title": "RCP/RCLM Runtime v3 Phase 12C memory and retrieval successor evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "accepted",
    "phase12b_reference_hash",
    "active_package_hash",
    "active_state_hash",
    "active_model_identity_hash",
    "active_generator_hash",
    "active_planner_hash",
    "invalid_proposal_hash",
    "invalid_validation_hash",
    "invalid_proposal_package_unchanged",
    "proposal_hash",
    "proposal_validation_hash",
    "deterministic_replays",
    "semantic_candidate_hash",
    "candidate_package_hash",
    "candidate_model_identity_hash",
    "candidate_memory_hash",
    "candidate_retrieval_hash",
    "phase6_hash",
    "lifecycle_certificate_hash",
    "lifecycle_transition_hash",
    "frontier_before",
    "frontier_after",
    "new_task_ids",
    "changed_components",
    "progress_ledger",
    "heldout_material_consumed",
    "manual_repairs",
    "claim_boundary",
    "summary_hash"
  ],
  "properties": {
    "schema_id": {"const": "runtime.v3.phase12c.evidence_summary.v1"},
    "accepted": {"const": true},
    "phase12b_reference_hash": {"$ref": "#/$defs/hash"},
    "active_package_hash": {"$ref": "#/$defs/hash"},
    "active_state_hash": {"$ref": "#/$defs/hash"},
    "active_model_identity_hash": {"$ref": "#/$defs/hash"},
    "active_generator_hash": {"$ref": "#/$defs/hash"},
    "active_planner_hash": {"$ref": "#/$defs/hash"},
    "invalid_proposal_hash": {"$ref": "#/$defs/hash"},
    "invalid_validation_hash": {"$ref": "#/$defs/hash"},
    "invalid_proposal_package_unchanged": {"const": true},
    "proposal_hash": {"$ref": "#/$defs/hash"},
    "proposal_validation_hash": {"$ref": "#/$defs/hash"},
    "deterministic_replays": {"const": true},
    "semantic_candidate_hash": {"$ref": "#/$defs/hash"},
    "candidate_package_hash": {"$ref": "#/$defs/hash"},
    "candidate_model_identity_hash": {"$ref": "#/$defs/hash"},
    "candidate_memory_hash": {"$ref": "#/$defs/hash"},
    "candidate_retrieval_hash": {"$ref": "#/$defs/hash"},
    "phase6_hash": {"$ref": "#/$defs/hash"},
    "lifecycle_certificate_hash": {"$ref": "#/$defs/hash"},
    "lifecycle_transition_hash": {"$ref": "#/$defs/hash"},
    "frontier_before": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "frontier_after": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "new_task_ids": {"const": ["lean.phase12.generation2.zero_le_macro"]},
    "changed_components": {"const": ["memory_state", "retrieval_policy"]},
    "progress_ledger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_id",
        "total_budget_hash",
        "generator_invocations",
        "rejected_attempts",
        "candidate_realizations",
        "candidate_evaluations",
        "accepted_promotions",
        "frontier_expansions",
        "manual_repairs",
        "target_frontier_cardinality"
      ],
      "properties": {
        "schema_id": {"const": "runtime.v3.phase12.progress_ledger.v1"},
        "total_budget_hash": {"$ref": "#/$defs/hash"},
        "generator_invocations": {"const": 4},
        "rejected_attempts": {"const": 2},
        "candidate_realizations": {"const": 2},
        "candidate_evaluations": {"const": 2},
        "accepted_promotions": {"const": 1},
        "frontier_expansions": {"const": 1},
        "manual_repairs": {"const": 0},
        "target_frontier_cardinality": {"const": 7}
      }
    },
    "heldout_material_consumed": {"const": false},
    "manual_repairs": {"const": 0},
    "claim_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "m1_generator_used_for_authoritative_proposals",
        "second_phase12_rejection_retained",
        "rejection_preserved_m1",
        "m1_to_m2_candidate_realized",
        "m1_to_m2_gate_d_transition_accepted",
        "m1_to_m2_promotion",
        "accepted_phase12_promotions",
        "strict_phase12_frontier_expansions",
        "phase12_exit_closed"
      ],
      "properties": {
        "m1_generator_used_for_authoritative_proposals": {"const": true},
        "second_phase12_rejection_retained": {"const": true},
        "rejection_preserved_m1": {"const": true},
        "m1_to_m2_candidate_realized": {"const": true},
        "m1_to_m2_gate_d_transition_accepted": {"const": true},
        "m1_to_m2_promotion": {"const": false},
        "accepted_phase12_promotions": {"const": 1},
        "strict_phase12_frontier_expansions": {"const": 1},
        "phase12_exit_closed": {"const": false}
      }
    },
    "summary_hash": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
