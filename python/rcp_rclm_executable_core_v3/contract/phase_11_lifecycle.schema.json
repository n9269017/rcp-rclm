{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rcp-rclm.org/schema/runtime-v3-phase-11-lifecycle-v1.json",
  "title": "RCP/RCLM Runtime v3 Phase 11B model-generated candidate lifecycle summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "contract_version",
    "accepted",
    "active_package_hash",
    "active_state_hash",
    "active_generator_hash",
    "active_planner_hash",
    "invalid_invocation_hash",
    "invalid_validation_hash",
    "alpha_invocation_hash",
    "alpha_candidate_fixture_hash",
    "alpha_phase6_hash",
    "alpha_rejection_reason",
    "beta_invocation_hash",
    "beta_candidate_fixture_hash",
    "beta_phase6_hash",
    "beta_candidate_package_hash",
    "beta_candidate_model_identity_hash",
    "successor_generator_hash",
    "successor_planner_hash",
    "lifecycle_certificate_hash",
    "lifecycle_transition_hash",
    "budget",
    "heldout_material_consumed",
    "deterministic_generator_replay",
    "proposal_invocations",
    "generator_replay_invocations",
    "claim_boundary",
    "summary_hash"
  ],
  "properties": {
    "schema_id": {"const": "runtime.v3.phase11b.evidence_summary.v1"},
    "contract_version": {"const": "rcp-rclm-executable-v3-phase-11b"},
    "accepted": {"const": true},
    "active_package_hash": {"$ref": "#/$defs/Hash"},
    "active_state_hash": {"$ref": "#/$defs/Hash"},
    "active_generator_hash": {"$ref": "#/$defs/Hash"},
    "active_planner_hash": {"$ref": "#/$defs/Hash"},
    "invalid_invocation_hash": {"$ref": "#/$defs/Hash"},
    "invalid_validation_hash": {"$ref": "#/$defs/Hash"},
    "alpha_invocation_hash": {"$ref": "#/$defs/Hash"},
    "alpha_candidate_fixture_hash": {"$ref": "#/$defs/Hash"},
    "alpha_phase6_hash": {"$ref": "#/$defs/Hash"},
    "alpha_rejection_reason": {"const": "protected_capability_regression"},
    "beta_invocation_hash": {"$ref": "#/$defs/Hash"},
    "beta_candidate_fixture_hash": {"$ref": "#/$defs/Hash"},
    "beta_phase6_hash": {"$ref": "#/$defs/Hash"},
    "beta_candidate_package_hash": {"$ref": "#/$defs/Hash"},
    "beta_candidate_model_identity_hash": {"$ref": "#/$defs/Hash"},
    "successor_generator_hash": {"$ref": "#/$defs/Hash"},
    "successor_planner_hash": {"$ref": "#/$defs/Hash"},
    "lifecycle_certificate_hash": {"$ref": "#/$defs/Hash"},
    "lifecycle_transition_hash": {"$ref": "#/$defs/Hash"},
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "budget_hash",
        "generator_invocations",
        "candidate_realizations",
        "candidate_evaluations",
        "manual_repairs"
      ],
      "properties": {
        "budget_hash": {"$ref": "#/$defs/Hash"},
        "generator_invocations": {"const": 3},
        "candidate_realizations": {"const": 2},
        "candidate_evaluations": {"const": 2},
        "manual_repairs": {"const": 0}
      }
    },
    "heldout_material_consumed": {"const": false},
    "deterministic_generator_replay": {"const": true},
    "proposal_invocations": {"const": 3},
    "generator_replay_invocations": {"const": 3},
    "claim_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_generated_candidate_realized",
        "model_generated_candidate_rejected",
        "later_fresh_candidate_accepted",
        "candidate_promoted",
        "successor_generator_planner_installed",
        "modified_successor_generator_used_recursively",
        "phase11_exit_closed"
      ],
      "properties": {
        "model_generated_candidate_realized": {"const": true},
        "model_generated_candidate_rejected": {"const": true},
        "later_fresh_candidate_accepted": {"const": true},
        "candidate_promoted": {"const": false},
        "successor_generator_planner_installed": {"const": true},
        "modified_successor_generator_used_recursively": {"const": false},
        "phase11_exit_closed": {"const": false}
      }
    },
    "summary_hash": {"$ref": "#/$defs/Hash"}
  },
  "$defs": {
    "Hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
