{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rcp-rclm.example/schemas/runtime-v3-phase-12d-generator-planner.json",
  "title": "RCP/RCLM Runtime v3 Phase 12D generator/planner successor evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "accepted",
    "phase12c_reference_hash",
    "active_package_hash",
    "active_state_hash",
    "active_model_identity_hash",
    "active_generator_hash",
    "active_planner_hash",
    "proposal_hash",
    "proposal_validation_hash",
    "deterministic_replay",
    "semantic_candidate_hash",
    "candidate_package_hash",
    "candidate_model_identity_hash",
    "candidate_generator_hash",
    "candidate_planner_hash",
    "successor_proposal_protocol_hash",
    "phase6_hash",
    "lifecycle_certificate_hash",
    "lifecycle_transition_hash",
    "frontier_before",
    "frontier_after",
    "new_task_ids",
    "changed_components",
    "progress_ledger",
    "heldout_material_consumed",
    "manual_repairs",
    "claim_boundary",
    "summary_hash"
  ],
  "properties": {
    "schema_id": {"const": "runtime.v3.phase12d.evidence_summary.v1"},
    "accepted": {"const": true},
    "phase12c_reference_hash": {"$ref": "#/$defs/hash"},
    "active_package_hash": {"$ref": "#/$defs/hash"},
    "active_state_hash": {"$ref": "#/$defs/hash"},
    "active_model_identity_hash": {"$ref": "#/$defs/hash"},
    "active_generator_hash": {"$ref": "#/$defs/hash"},
    "active_planner_hash": {"$ref": "#/$defs/hash"},
    "proposal_hash": {"$ref": "#/$defs/hash"},
    "proposal_validation_hash": {"$ref": "#/$defs/hash"},
    "deterministic_replay": {"const": true},
    "semantic_candidate_hash": {"$ref": "#/$defs/hash"},
    "candidate_package_hash": {"$ref": "#/$defs/hash"},
    "candidate_model_identity_hash": {"$ref": "#/$defs/hash"},
    "candidate_generator_hash": {"$ref": "#/$defs/hash"},
    "candidate_planner_hash": {"$ref": "#/$defs/hash"},
    "successor_proposal_protocol_hash": {"$ref": "#/$defs/hash"},
    "phase6_hash": {"$ref": "#/$defs/hash"},
    "lifecycle_certificate_hash": {"$ref": "#/$defs/hash"},
    "lifecycle_transition_hash": {"$ref": "#/$defs/hash"},
    "frontier_before": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "frontier_after": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "new_task_ids": {
      "const": ["lean.phase12.generation3.lt_succ_planner_macro"]
    },
    "changed_components": {
      "const": ["generator_policy", "planner_policy"]
    },
    "progress_ledger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_id",
        "total_budget_hash",
        "generator_invocations",
        "rejected_attempts",
        "candidate_realizations",
        "candidate_evaluations",
        "accepted_promotions",
        "frontier_expansions",
        "manual_repairs",
        "target_frontier_cardinality"
      ],
      "properties": {
        "schema_id": {"const": "runtime.v3.phase12.progress_ledger.v1"},
        "total_budget_hash": {"$ref": "#/$defs/hash"},
        "generator_invocations": {"const": 5},
        "rejected_attempts": {"const": 2},
        "candidate_realizations": {"const": 3},
        "candidate_evaluations": {"const": 3},
        "accepted_promotions": {"const": 2},
        "frontier_expansions": {"const": 2},
        "manual_repairs": {"const": 0},
        "target_frontier_cardinality": {"const": 7}
      }
    },
    "heldout_material_consumed": {"const": false},
    "manual_repairs": {"const": 0},
    "claim_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "m2_generator_used_for_authoritative_proposal",
        "m2_to_m3_candidate_realized",
        "m2_to_m3_gate_d_transition_accepted",
        "generation3_generator_installed",
        "generation3_planner_installed",
        "m2_to_m3_promotion",
        "accepted_phase12_promotions",
        "strict_phase12_frontier_expansions",
        "phase12_exit_closed"
      ],
      "properties": {
        "m2_generator_used_for_authoritative_proposal": {"const": true},
        "m2_to_m3_candidate_realized": {"const": true},
        "m2_to_m3_gate_d_transition_accepted": {"const": true},
        "generation3_generator_installed": {"const": true},
        "generation3_planner_installed": {"const": true},
        "m2_to_m3_promotion": {"const": false},
        "accepted_phase12_promotions": {"const": 2},
        "strict_phase12_frontier_expansions": {"const": 2},
        "phase12_exit_closed": {"const": false}
      }
    },
    "summary_hash": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
