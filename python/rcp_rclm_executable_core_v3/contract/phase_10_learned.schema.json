{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rcp-rclm.org/schema/runtime-v3-phase-10-learned-v1.json",
  "title": "RCP/RCLM Runtime v3 Phase 10B learned evidence summary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "accepted",
    "predecessor_package_hash",
    "candidate_package_hash",
    "predecessor_model_identity_hash",
    "candidate_model_identity_hash",
    "protected_task_id",
    "new_heldout_task_id",
    "predecessor_protected_verifier_report_hash",
    "candidate_protected_verifier_report_hash",
    "candidate_heldout_verifier_report_hash",
    "information_report_hash",
    "phase9_transition_report_hash",
    "phase9_transition_accepted",
    "bootstrap_request_hash",
    "successor_request_hash",
    "heldout_policy_hash",
    "claim_boundary",
    "summary_hash"
  ],
  "properties": {
    "schema_id": {
      "const": "runtime.v3.phase10.learned_evidence_summary.v1"
    },
    "accepted": {
      "const": true
    },
    "predecessor_package_hash": {
      "$ref": "#/$defs/Hash"
    },
    "candidate_package_hash": {
      "$ref": "#/$defs/Hash"
    },
    "predecessor_model_identity_hash": {
      "$ref": "#/$defs/Hash"
    },
    "candidate_model_identity_hash": {
      "$ref": "#/$defs/Hash"
    },
    "protected_task_id": {
      "const": "lean.phase10.protected.reflexive_seven"
    },
    "new_heldout_task_id": {
      "const": "lean.phase10.heldout.linear_gap"
    },
    "predecessor_protected_verifier_report_hash": {
      "$ref": "#/$defs/Hash"
    },
    "candidate_protected_verifier_report_hash": {
      "$ref": "#/$defs/Hash"
    },
    "candidate_heldout_verifier_report_hash": {
      "$ref": "#/$defs/Hash"
    },
    "information_report_hash": {
      "$ref": "#/$defs/Hash"
    },
    "phase9_transition_report_hash": {
      "$ref": "#/$defs/Hash"
    },
    "phase9_transition_accepted": {
      "const": true
    },
    "bootstrap_request_hash": {
      "$ref": "#/$defs/Hash"
    },
    "successor_request_hash": {
      "$ref": "#/$defs/Hash"
    },
    "heldout_policy_hash": {
      "$ref": "#/$defs/Hash"
    },
    "claim_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trained_sparse_language_model",
        "untrusted_worker_protocol",
        "authoritative_exact_inference",
        "pinned_lean_task_certification",
        "selected_kl_diagonal_qre",
        "phase9_gate_d_transition",
        "phase6_realization",
        "atomic_promotion",
        "independent_replay",
        "phase10_exit_closed"
      ],
      "properties": {
        "trained_sparse_language_model": {
          "const": true
        },
        "untrusted_worker_protocol": {
          "const": true
        },
        "authoritative_exact_inference": {
          "const": true
        },
        "pinned_lean_task_certification": {
          "const": true
        },
        "selected_kl_diagonal_qre": {
          "const": true
        },
        "phase9_gate_d_transition": {
          "const": true
        },
        "phase6_realization": {
          "const": false
        },
        "atomic_promotion": {
          "const": false
        },
        "independent_replay": {
          "const": false
        },
        "phase10_exit_closed": {
          "const": false
        }
      }
    },
    "summary_hash": {
      "$ref": "#/$defs/Hash"
    }
  },
  "$defs": {
    "Hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
